{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "permission": {
    "*": "allow",
    "sudo *": "deny",
    "rm -rf /": "deny",
    "rm -rf /*": "deny",
    "rm -rf ~": "deny",
    "rm -rf ~/*": "deny",
    ":(){:|:&};:": "deny",
    "doom_loop": "deny"
  },
  "model": "opencode/minimax-m2.5-free",
  "small_model": "opencode/minimax-m2.5-free",
  "disabled_providers": ["openai"],
  "plugin": [
    "openslimedit@1.0.4",
    "opencode-ignore@1.1.0",
    "@gotgenes/opencode-agent-identity@3.0.1"
  ],
  "watcher": { "ignore": ["node_modules/**", "dist/**", ".git/**", ".venv/**"] },
  "mcp": {
    "ref-tools": {
      "type": "remote",
      "url": "https://api.ref.tools/mcp"
    },
    "github-mcp-server": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "experimental": {
    "continue_loop_on_deny": false,
    "mcp_timeout": 30000,
    "openTelemetry": false,
    "batch_tool": true
  }
}
