{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "permission": {
    "*": "allow",
    "sudo *": "deny",
    "rm -rf /": "deny",
    "rm -rf /*": "deny",
    "rm -rf ~": "deny",
    "rm -rf ~/*": "deny",
    ":(){:|:&};:": "deny",
    "doom_loop": "deny"
  },
  "plugin": [
    "openslimedit@latest",
    "opencode-ignore@latest",
    "@gotgenes/opencode-agent-identity@latest",
    "@spoons-and-mirrors/subtask2@latest",
    "opencode-pty@latest",
    "openfundus@latest",
  ],
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"]
    }
  }
}
