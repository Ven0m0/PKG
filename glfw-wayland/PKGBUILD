prepare() {
  cd "$srcdir/glfw-$pkgver"
  rm -rf build-wayland || true
  mkdir build-wayland
  for patch in "$srcdir"/*.patch; do
    printf 'Applying patch %s\n' "$patch"
    patch -p1 <"$patch"
  done
}

build() {
  cd "$srcdir/glfw-$pkgver/build-wayland"
  cmake .. -GNinja -DCMAKE_BUILD_TYPE=Release -DCMAKE_SKIP_INSTALL_RPATH=YES -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_INSTALL_LIBDIR=lib -DBUILD_SHARED_LIBS=ON -DGLFW_USE_WAYLAND=ON \
    -DGLFW_BUILD_EXAMPLES=NO -DGLFW_BUILD_X11=NO -DBUILD_SHARED_LIBS=ON -Wno-dev
  cmake --build . -j"$(nproc)"
}

package() {
  cd "$srcdir/glfw-$pkgver"/build-wayland
  DESTDIR=$pkgdir cmake --install .
  cd ..
  install -Dm644 LICENSE.md "$pkgdir/usr/share/licenses/$pkgname/LICENSE.md"
}
